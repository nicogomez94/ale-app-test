generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum PlanType {
  TRIAL
  EMPRENDEDOR
  PROFESIONAL
  AGENCIA
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum UserStatus {
  ACTIVO
  INACTIVO
}

enum PolicyStatus {
  ACTIVA
  VENCE_PRONTO
  VENCIDA
}

enum PolicyType {
  INDIVIDUAL
  EMPRESA
}

enum CompanyType {
  ART
  FLOTAS
  TRO
  CONSORCIO
  INTEGRAL_DE_COMERCIO
}

enum LifePolicyType {
  VIDA
  RETIRO
}

// ─── Models ──────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  password         String
  nombre           String
  telefono         String?
  direccion        String?
  avatar           String?
  matriculaPas     String?
  isAdmin          Boolean    @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  plan             PlanType   @default(TRIAL)
  planVencimiento  DateTime?
  trialInicio      DateTime   @default(now())
  trialFin         DateTime?
  estado           UserStatus @default(ACTIVO)
  referralCode     String     @unique
  referidosMes     Int        @default(0)
  referidosTotales Int        @default(0)
  lastLogin        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  clientes         Client[]
  empresas         Company[]
  polizas          Policy[]
  lifePolizas      LifePolicy[]
  commissionCloses CommissionClose[]
  referrals        Referral[]
  subscriptions    Subscription[]
  payments         Payment[]
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  nombre    String
  dni       String
  telefono  String
  email     String
  direccion String?
  cp        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  polizas Policy[]

  @@index([userId])
}

model Company {
  id          String      @id @default(uuid())
  userId      String
  razonSocial String
  cuit        String
  ramo        String?
  empleados   Int?
  vehiculos   Int?
  aseguradora String
  email       String
  telefono    String
  direccion   String?
  cp          String?
  tipo        CompanyType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  polizas Policy[]

  @@index([userId])
}

model Policy {
  id                 String       @id @default(uuid())
  userId             String
  clienteId          String?
  companyId          String?
  clienteNombre      String
  clienteDni         String?
  clienteTelefono    String?
  aseguradora        String
  rubro              String
  numeroPoliza       String
  fechaInicio        DateTime
  fechaVencimiento   DateTime
  medioPago          String?
  prima              Float
  porcentajeComision Float
  comisionCalculada  Float
  estado             PolicyStatus @default(ACTIVA)
  tipo               PolicyType   @default(INDIVIDUAL)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cliente Client?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([estado])
  @@index([fechaVencimiento])
}

model LifePolicy {
  id             String         @id @default(uuid())
  userId         String
  cliente        String
  cuit           String
  aseguradora    String
  tipo           LifePolicyType
  sumaAsegurada  Float?
  prima          Float?
  aporteMensual  Float?
  fondoAcumulado Float?
  email          String?
  telefono       String?
  cp             String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CommissionClose {
  id            String   @id @default(uuid())
  userId        String
  mes           Int
  anio          Int
  totalPrima    Float
  comisionBruta Float
  crecimiento   Float?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mes, anio])
  @@index([userId])
}

model Referral {
  id            String   @id @default(uuid())
  referrerId    String
  referredEmail String
  status        String   @default("pending")
  mes           Int
  anio          Int
  createdAt     DateTime @default(now())

  referrer User @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

model Subscription {
  id                 String       @id @default(uuid())
  userId             String
  plan               PlanType
  billingCycle       BillingCycle @default(MONTHLY)
  precio             Float
  inicio             DateTime
  fin                DateTime
  estado             String       @default("activo")
  providerStatus     String?
  mpPaymentId        String?
  mpPreapprovalId    String?      @unique
  mpPreapprovalPlanId String?
  nextPaymentDate    DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mpPreapprovalPlanId])
}

model Payment {
  id             String   @id @default(uuid())
  userId         String
  monto          Float
  plan           String
  metodoPago     String?
  mpPaymentId    String?
  mpPreapprovalId String?
  estado         String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mpPaymentId])
  @@index([mpPreapprovalId])
}

model SubscriptionProviderPlan {
  id                String       @id @default(uuid())
  plan              PlanType
  billingCycle      BillingCycle
  price             Float
  reason            String
  status            String
  mpPreapprovalPlanId String     @unique
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([plan, billingCycle])
  @@index([status])
}

model LandingContactLead {
  id        String   @id @default(uuid())
  nombre    String
  email     String
  telefono  String?
  asunto    String
  mensaje   String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model LandingProducerLead {
  id             String   @id @default(uuid())
  nombre         String
  email          String
  telefono       String
  provincia      String?
  experiencia    String?
  mensaje        String?
  cvOriginalName String?
  cvMimeType     String?
  cvSizeBytes    Int?
  cvContent      Bytes?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}
